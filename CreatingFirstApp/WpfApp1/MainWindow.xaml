<Window x:Class="MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Viewbox Stretch="Uniform">
        <Grid Width="800" Height="450">
            <Label Content="Sign In" FontSize="25" HorizontalAlignment="Left" Margin="668,148,0,0" VerticalAlignment="Top"/>
            <local:ClearableTextBox x:Name="txtUsername" Placeholder="Username" Margin="652,225,29,204"></local:ClearableTextBox>
            <local:ClearableTextBox x:Name="txtPassword" Placeholder="Password" Margin="652,261,29,168"></local:ClearableTextBox>
            <Button Name="btnSignIn" Content="Sign In" HorizontalAlignment="Left" Margin="731,294,0,0" VerticalAlignment="Top" Click="LogIn_Click"/>
            <TextBlock FontSize="10" HorizontalAlignment="Left" Margin="538,404,0,0" VerticalAlignment="Top">
                <Run Text="Don't have an account? "/>
                <Hyperlink x:Name="lnkRegister" Click="lnkRegister_Click">Sign Up</Hyperlink>
                <Run Text=" or continue as "/>
                <Hyperlink x:Name="lnkGuest" Click="lnkGuest_Click">Guest</Hyperlink>
            </TextBlock>

        </Grid>
    </Viewbox>
</Window>
